{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022"],
    "types": ["node"],
    "sourceMap": true,
    "declaration": false,
    "jsx": "preserve"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "dist-test", "node_modules", "media"]
}
