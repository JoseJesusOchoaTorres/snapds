{
  "name": "snapds",
  "displayName": "Snapds",
  "description": "Browse, configure, and drop Snapds components into your React code.",
  "version": "0.1.0",
  "publisher": "Octojose",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "react",
    "design system",
    "components",
    "monorepo",
    "ai skills"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JoseJesusOchoaTorres/snapds.git"
  },
  "bugs": {
    "url": "https://github.com/JoseJesusOchoaTorres/snapds/issues"
  },
  "homepage": "https://github.com/JoseJesusOchoaTorres/snapds#readme",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:snapds.gallery",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "snapdsSidebar",
          "title": "Snapds",
          "icon": "media/icons/ds.svg"
        }
      ]
    },
    "views": {
      "snapdsSidebar": [
        {
          "id": "snapds.gallery",
          "name": "Components",
          "type": "webview",
          "contextualTitle": "Snapds"
        }
      ]
    },
    "commands": [
      {
        "command": "snapds.openSettings",
        "title": "Snapds: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "snapds.openPropsPanel",
        "title": "Snapds: Open Props Panel"
      },
      {
        "command": "snapds.generateSkills",
        "title": "Snapds: Generate Skills",
        "category": "Snapds"
      },
      {
        "command": "snapds.regenerateSkills",
        "title": "Snapds: Regenerate All Skills",
        "category": "Snapds"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "snapds.openSettings",
          "when": "view == snapds.gallery",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Snapds",
      "properties": {
        "snapds.packages": {
          "type": "array",
          "default": [],
          "description": "Registered Snapds packages.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "version",
              "importPath"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "npm package name, e.g. @acme/ui"
              },
              "version": {
                "type": "string",
                "description": "Semver pin used as cache key"
              },
              "importPath": {
                "type": "string",
                "description": "Import specifier used in codegen (often equals name)"
              },
              "tsconfigPath": {
                "type": "string",
                "description": "Optional path to a tsconfig used by react-docgen-typescript"
              },
              "excluded": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Component names the user de-selected"
              },
              "manual": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Component names added manually"
              }
            }
          }
        },
        "snapds.skills": {
          "type": "object",
          "default": {},
          "description": "Agent skills generation configuration.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable the AI / skills section"
            },
            "formats": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "augment",
                  "generic"
                ]
              },
              "description": "Skill formats to generate"
            },
            "destination": {
              "type": "string",
              "enum": [
                "workspace",
                "custom"
              ],
              "description": "Where to write skills"
            },
            "customPath": {
              "type": "string",
              "description": "Destination folder when destination is 'custom'"
            },
            "autoGenerate": {
              "type": "boolean",
              "description": "Auto-generate skills when components are added"
            },
            "instructions": {
              "type": "object",
              "description": "Free-text guidance per component id (pkg#Name)",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "icon:png": "node scripts/render-icon.cjs",
    "test": "node esbuild.test.mjs && node --test \"dist-test/**/*.test.cjs\"",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "react-docgen-typescript": "^2.2.2"
  }
}
