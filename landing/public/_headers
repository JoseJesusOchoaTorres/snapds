# Cloudflare Pages response headers for the Snapds site (Next.js static export).
# Parsed by Pages and applied to static asset responses (not served as an asset).

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; font-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# Next.js emits content-hashed files under /_next/static, safe to cache forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind search index (content-hashed), safe to cache forever.
/_pagefind/*
  Cache-Control: public, max-age=31536000, immutable
