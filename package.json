{
  "name": "snapds-monorepo",
  "private": false,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -k -n ext,gal,prp,set,cp \"pnpm dev:extension\" \"pnpm dev:gallery\" \"pnpm dev:props\" \"pnpm dev:settings\" \"pnpm dev:copy\"",
    "dev:extension": "pnpm --filter snapds run watch",
    "dev:gallery": "pnpm --filter webview-gallery run dev",
    "dev:props": "pnpm --filter webview-props run dev",
    "dev:settings": "pnpm --filter webview-settings run dev",
    "dev:landing": "pnpm --filter landing run dev",
    "build:landing": "pnpm --filter landing run build",
    "deploy:landing": "npx wrangler pages deploy landing/out --project-name snapds",
    "dev:copy": "chokidar \"webview-gallery/dist/**\" \"webview-props/dist/**\" \"webview-settings/dist/**\" -c \"node scripts/copy-webviews.mjs\"",
    "build": "pnpm -r run build && node scripts/copy-webviews.mjs",
    "test": "pnpm -r run test",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "package": "pnpm run build && pnpm --filter snapds run package"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.2.2"
  }
}
