{
  "name": "snapds-monorepo",
  "private": false,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently -k -n ext,web,cp \"pnpm dev:extension\" \"pnpm dev:webviews\" \"pnpm dev:copy\"",
    "dev:extension": "pnpm --filter snapds run dev",
    "dev:webviews": "pnpm --filter snapds run dev:webviews",
    "dev:landing": "pnpm --filter landing run dev",
    "build:landing": "pnpm --filter landing run build",
    "deploy:landing": "npx wrangler pages deploy landing/out --project-name snapds",
    "dev:copy": "chokidar \"extension/webviews/gallery/dist/**\" \"extension/webviews/props/dist/**\" \"extension/webviews/settings/dist/**\" -c \"node scripts/copy-webviews.mjs\"",
    "build": "pnpm -r run build && node scripts/copy-webviews.mjs",
    "test": "pnpm -r run test",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "package": "pnpm run build && pnpm --filter snapds run package"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.2.2",
    "husky": "^9.0.0"
  }
}
